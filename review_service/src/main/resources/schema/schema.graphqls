type Query {
    review(id: ID!): Review
}

type Review {
    id: ID!
    rating: Int!
    comment: String
    user: User
    show: Show
}

type User @key(fields: "id") @extends {
    id: ID! @external
    reviews: [Review]
}

type Show @key(fields: "id") @extends {
    id: ID! @external
    reviews: [Review]
}